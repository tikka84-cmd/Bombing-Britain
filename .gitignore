# Raw dataset — not redistributed while reuse licence is unresolved
data-pipeline/raw/*
!data-pipeline/raw/.gitkeep

# Pipeline output artefacts (regenerated by the build scripts)
data-pipeline/out/*
!data-pipeline/out/.gitkeep

# Offline gazetteer (GeoNames, CC BY 4.0) — downloaded, not redistributed here
data-pipeline/gazetteer/*
!data-pipeline/gazetteer/.gitkeep

# App data artefact (derived dataset) — not published while licence is unresolved
app/public/raids.geojson

# Node
node_modules/
app/node_modules/

# Build output
app/dist/
dist/

# Logs
*.log
npm-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Netlify
.netlify/

# Local editor / harness config (machine-specific)
.claude/
